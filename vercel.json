{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.creatives-takeover.com" }],
      "destination": "https://creatives-takeover.com/$1",
      "permanent": true
    },
    { "source": "/community/co-founders/:path*", "destination": "/co-founder/:path*", "permanent": true },
    { "source": "/community/angels/:path*", "destination": "/investors/:path*", "permanent": true },
    { "source": "/community/co-founders", "destination": "/co-founder", "permanent": true },
    { "source": "/community/angels", "destination": "/investors", "permanent": true },
    { "source": "/community/:path*", "destination": "/mentorship", "permanent": true },
    { "source": "/community", "destination": "/mentorship", "permanent": true },
    { "source": "/waitlist/templates", "destination": "/demo-studio/classic/templates", "permanent": true },
    { "source": "/waitlist", "destination": "/demo-studio/classic", "permanent": true },
    { "source": "/waitlist-maker", "destination": "/demo-studio/classic", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "^(?<slug>[a-z0-9-]+)\\.creatives-takeover\\.com$" }],
      "destination": "/api/published-site?slug=:slug&p=:path"
    },
    { "source": "/pricing", "destination": "/pricing/index.html" },
    { "source": "/pricing/", "destination": "/pricing/index.html" },
    { "source": "/resources", "destination": "/resources/index.html" },
    { "source": "/resources/", "destination": "/resources/index.html" },
    { "source": "/newspaper/:slug", "destination": "/api/newspaper-og?slug=:slug" },
    { "source": "/stories/:slug", "destination": "/api/newspaper-og?slug=:slug" },
    { "source": "/sitemap-articles.xml", "destination": "/api/sitemap-articles" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/og-icp",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(favicon.*|apple-touch-icon.*|site.webmanifest|robots.txt|sitemap.xml|llms.txt|og-image.png)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob: https://cdn.tailwindcss.com https://www.googletagmanager.com https://www.google-analytics.com https://*.contentsquare.net https://*.contentsquare.com https://cdn.amplitude.com https://cloud.umami.is https://*.webcontainer-api.io https://*.staticblitz.com; worker-src 'self' blob:; frame-src 'self' blob: https://*.webcontainer-api.io https://*.staticblitz.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.tailwindcss.com; img-src 'self' https: data: blob:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://www.google-analytics.com https://analytics.google.com https://www.google.com https://stats.g.doubleclick.net https://api.amplitude.com https://api2.amplitude.com https://api.posthog.com https://app.posthog.com https://eu.posthog.com https://us.i.posthog.com https://us-assets.i.posthog.com https://*.contentsquare.net https://*.contentsquare.com https://cdn.amplitude.com https://cloud.umami.is https://gateway.umami.is https://api.mapbox.com https://events.mapbox.com https://*.webcontainer-api.io https://*.staticblitz.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "credentialless" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), serial=()" },
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
