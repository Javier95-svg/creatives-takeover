# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your-anon-public-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Analytics Configuration
VITE_AMPLITUDE_API_KEY=your-amplitude-browser-api-key
VITE_POSTHOG_API_KEY=your-posthog-project-api-key
VITE_POSTHOG_API_HOST=https://us.i.posthog.com

# Supabase Edge Function secrets for backend analytics events
# Configure these in Supabase Dashboard > Edge Functions > Secrets
AMPLITUDE_API_KEY=your-amplitude-server-api-key
POSTHOG_PROJECT_API_KEY=your-posthog-project-api-key
POSTHOG_HOST=https://us.i.posthog.com

# MVP Builder mandatory integrations
# Configure these in Supabase Dashboard > Edge Functions > Secrets
INTEGRATION_TOKEN_SECRET=replace-with-a-long-random-secret-at-least-32-chars
GITHUB_APP_CLIENT_ID=your-github-app-oauth-client-id
GITHUB_APP_CLIENT_SECRET=your-github-app-oauth-client-secret
SUPABASE_OAUTH_CLIENT_ID=your-supabase-oauth-client-id
SUPABASE_OAUTH_CLIENT_SECRET=your-supabase-oauth-client-secret

# Mapbox Configuration (optional - for location search)
# Get your token from: https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=your-mapbox-public-token

# Feature flags (set to "true" to enable)
VITE_ENABLE_MONTHLY_CREDITS_GRANT=false

# App version (injected at build time, e.g. "1.0.0")
VITE_APP_VERSION=0.0.0

# Stripe (server-side only — never expose to the browser)
# Configure these in Supabase Dashboard > Edge Functions > Secrets
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-signing-secret

# PostHog (server-side edge function usage — VITE_ equivalents above are for the browser SDK)
VITE_POSTHOG_KEY=your-posthog-project-api-key
VITE_POSTHOG_HOST=https://us.i.posthog.com
# Dashboard command-center rollout (0-100, stable user bucketing).
VITE_DASHBOARD_V2_ROLLOUT_PERCENT=0
# Non-blocking AI tie-breaker. Deterministic recommendations remain the fallback.
VITE_DASHBOARD_AI_RANKING_ENABLED=false
VITE_MESSAGES_INBOX_V2_ENABLED=true
VITE_ONBOARDING_ACTIVATION_V2=false
