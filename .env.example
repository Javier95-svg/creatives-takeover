# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your-anon-public-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Analytics Configuration
VITE_AMPLITUDE_API_KEY=your-amplitude-browser-api-key
VITE_POSTHOG_API_KEY=your-posthog-project-api-key
VITE_POSTHOG_API_HOST=https://us.i.posthog.com

# Supabase Edge Function secrets for backend analytics events
# Configure these in Supabase Dashboard > Edge Functions > Secrets
AMPLITUDE_API_KEY=your-amplitude-server-api-key
POSTHOG_PROJECT_API_KEY=your-posthog-project-api-key
POSTHOG_HOST=https://us.i.posthog.com

# Mapbox Configuration (optional - for location search)
# Get your token from: https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=your-mapbox-public-token
